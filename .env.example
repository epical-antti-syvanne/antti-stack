# Antti Stack environment variables
#
# Copy this file to .env and fill in the values if you use a dotenv loader.
# The CLI reads these from process.env - no .env auto-loading is built in.
# On Windows, `antti meme <input>` can prompt for these and save them to your user environment.

# imgflip API credentials
# Required for: antti meme <input>  (to generate a real meme URL)
# Without these, the meme command still prints the template text; it just skips the API call.
# Get your credentials at https://imgflip.com/signup (free account).
IMGFLIP_USERNAME=
IMGFLIP_PASSWORD=

# Memory file path (default: .antti/memory.jsonl)
# Override if you want memory stored somewhere else.
# ANTTI_MEMORY_PATH=.antti/memory.jsonl
